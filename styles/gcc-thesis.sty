\ctexset{
  chapter = {
    name = {,},
    number = \arabic{chapter},
    format = \centering\gccChapterFont,
    aftername = \quad,
    beforeskip = 10pt,
    afterskip = 12pt
  },
  section = {
    format = \gccSectionFont,
    beforeskip = 8pt,
    afterskip = 4pt
  },
  subsection = {
    format = \gccSectionFont,
    beforeskip = 8pt,
    afterskip = 4pt
  }
}

