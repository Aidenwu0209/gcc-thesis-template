\newsavebox{\gccFitBox}
\newcommand{\gccFitText}[2]{%
  \sbox{\gccFitBox}{#2}%
  \ifdim\wd\gccFitBox>#1
    \resizebox{#1}{!}{#2}%
  \else
    #2%
  \fi
}

\newcommand{\gccUnderlineField}[2][8.7cm]{%
  \underline{\makebox[#1][c]{\gccFitText{#1}{#2}}}%
}
\newcommand{\gccCoverField}[2]{%
  {\gccSong\bfseries\zihao{3}\selectfont #1\gccUnderlineField[9.6cm]{#2}\par}%
}
\newcommand{\gccCoverTitleLine}[1]{%
  \underline{\makebox[12.3cm][c]{\gccFitText{12.3cm}{{\gccSong\bfseries\zihao{-2}\selectfont #1}}}}\par
}

\newcommand{\gccMakeCover}{%
  \thispagestyle{empty}%
  \begingroup
  \setstretch{1.25}
  \noindent{\gccSong\zihao{-4}\selectfont 论文编号：\gccPaperNo}\par
  \vspace*{1.35cm}
  \begin{center}
    {\gccSong\bfseries\zihao{0}\selectfont \gccSchoolName\par}
    \vspace{0.9cm}
    {\gccSong\bfseries\zihao{1}\selectfont \gccThesisType\par}
    \vspace{1.25cm}
    {\gccSong\bfseries\zihao{3}\selectfont 题\hspace{1.6em}目：\par}
    \vspace{0.28cm}
    \gccCoverTitleLine{\gccCoverTitleLineA}
    \ifdefempty{\gccCoverTitleLineB}{}{%
      \vspace{0.18cm}
      \gccCoverTitleLine{\gccCoverTitleLineB}
    }
    \vspace{1.2cm}
    \gccCoverField{姓\hspace{1.6em}名：}{\gccAuthor}
    \vspace{0.35cm}
    \gccCoverField{学\hspace{1.6em}号：}{\gccStudentId}
    \vspace{0.35cm}
    \gccCoverField{学\hspace{1.6em}院：}{\gccCollege}
    \vspace{0.35cm}
    \gccCoverField{专业班级：}{\gccMajorClass}
    \vspace{0.35cm}
    \gccCoverField{指导教师：}{\gccSupervisor}
    \vfill
    {\gccSong\bfseries\zihao{3}\selectfont \gccCoverDate\par}
  \end{center}
  \endgroup
}

