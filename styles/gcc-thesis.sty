}

\newcommand{\gccSetUnifiedCJKFont}[1]{%
  \setCJKmainfont[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
  \setCJKmonofont[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
  \newCJKfontfamily\gccSong[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
  \newCJKfontfamily\gccHei[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
  \newCJKfontfamily\gccFangSong[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
  \newCJKfontfamily\gccKai[AutoFakeBold=2,AutoFakeSlant=0.2]{#1}%
}

\IfFontExistsTF{Songti SC}{
  \gccSetUnifiedCJKFont{Songti SC}
}{
  \IfFontExistsTF{FandolSong-Regular}{
    \gccSetUnifiedCJKFont{FandolSong-Regular}
  }{
    \IfFontExistsTF{Noto Serif CJK SC}{
      \gccSetUnifiedCJKFont{Noto Serif CJK SC}
    }{
      \gccSetUnifiedCJKFont{SimSun}
    }
  }
}

